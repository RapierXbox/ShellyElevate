<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <Button
                android:id="@+id/findURLButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/findIPButtonText"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/webviewURL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:hint="@string/homeAssistantIpEditTextPreviewIp"
                android:imeOptions="actionDone"
                android:inputType="textUri"
                android:textSize="18sp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/ignoreSslErrors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:text="@string/ignore_ssl_errors"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchOnSwipe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/switchOnSwipeText"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/powerButtonAutoReboot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/power_button_auto_reboot"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <!-- Button-to-Relay Mapping -->
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/buttonRelayEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/button_relay_mapping"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <LinearLayout
                android:id="@+id/buttonRelayMappingLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/buttonRelayMap0Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/buttonRelayMap0Label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:labelFor="@id/buttonRelayMap0"
                        android:textSize="18sp" />

                    <Spinner
                        android:id="@+id/buttonRelayMap0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:spinnerMode="dialog" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/buttonRelayMap1Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/buttonRelayMap1Label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:labelFor="@id/buttonRelayMap1"
                        android:textSize="18sp" />

                    <Spinner
                        android:id="@+id/buttonRelayMap1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:spinnerMode="dialog" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/buttonRelayMap2Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/buttonRelayMap2Label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:labelFor="@id/buttonRelayMap2"
                        android:textSize="18sp" />

                    <Spinner
                        android:id="@+id/buttonRelayMap2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:spinnerMode="dialog" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/buttonRelayMap3Layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/buttonRelayMap3Label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:labelFor="@id/buttonRelayMap3"
                        android:textSize="18sp" />

                    <Spinner
                        android:id="@+id/buttonRelayMap3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:spinnerMode="dialog" />

                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/automaticBrightness"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/automaticBrightnessText"
                android:textSize="18sp" />

            <LinearLayout
                android:id="@+id/minBrightnessLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="@string/min_brightness"
                    android:textSize="18sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/min_brightness"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="1"
                    android:valueTo="255" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/brightnessSettingLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="@string/brightness"
                    android:textSize="18sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/brightnessSetting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="1"
                    android:valueTo="255" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/volumeSettingLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="@string/volume"
                    android:textSize="18sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/volumeSetting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="0"
                    android:valueTo="100"
                    android:stepSize="1" />

            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/screenSaver"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/ScreenSaverText"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <LinearLayout
                android:id="@+id/screenSaverDelayLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/screen_saver_delay"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/screenSaverDelay"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/screen_saver_delay_hint"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/screenSaverTypeLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/screenSaverTypeText"
                    android:textSize="18sp" />

                <Spinner
                    android:id="@+id/screenSaverType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:spinnerMode="dialog" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/min_brightness_screen_saver_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="@string/min_brightness"
                    android:textSize="18sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/screensaver_min_brightness"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:valueFrom="1"
                    android:valueTo="255" />

            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/wakeOnProximity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/wake_on_proximity"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <LinearLayout
                android:id="@+id/proximityKeepAwakeLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/proximity_keep_awake_seconds"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/proximityKeepAwakeSeconds"
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:ems="3"
                    android:gravity="end"
                    android:hint="@string/proximity_keep_awake_hint"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:textSize="18sp" />
            </LinearLayout>


            <LinearLayout
                android:id="@+id/sensorStatusLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/proximitySensorAvailability"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/proximity_sensor_available_default"
                    android:textSize="18sp"
                    tools:text="Proximity sensor available to app: Yes" />

                <TextView
                    android:id="@+id/proximitySensorValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/proximity_sensor_value_default"
                    android:textSize="18sp"
                    tools:text="Proximity sensor current value: 0.00" />

                <TextView
                    android:id="@+id/proximitySensorState"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/proximity_sensor_state_default"
                    android:textSize="18sp"
                    tools:text="Proximity sensor state: FAR" />

                <TextView
                    android:id="@+id/lightSensorValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/light_sensor_value_default"
                    android:textSize="18sp"
                    tools:text="Light sensor current value: 4.21 lx" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/httpServerEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/http_server_enabled"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <LinearLayout
                android:id="@+id/httpServerAddressLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/http_server_address"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/httpServerAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="0dp"
                    android:textSize="18sp"
                    tools:text="http://127.0.0.1:8080" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/httpServerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/httpServerText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/http_server_status_default"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/httpServerStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:textSize="18sp"
                    tools:text="@string/http_server_running" />

                <Button
                    android:id="@+id/httpServerButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingVertical="0dp"
                    android:text="@string/start"
                    android:textSize="18sp" />
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/extendedJavascriptInterface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/extended_js_interface"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/mediaEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/media_enabled"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/mqttEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/mqtt"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <LinearLayout
                android:id="@+id/mqttClientIdLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/client_id"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/mqttClientId"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/mqtt_client_id_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textUri"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mqttBrokerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/broker_address"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/mqttBroker"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/mqttbroker_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textUri"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mqttPortLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/broker_port"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/mqttPort"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/mqtt_port_hint"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mqttUsernameLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/username"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/mqttUsername"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/mqtt_username_hint"
                    android:imeOptions="actionDone"
                    android:inputType="text"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mqttPasswordLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/password"
                    android:textSize="18sp" />

                <EditText
                    android:id="@+id/mqttPassword"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:hint="@string/mqtt_password_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textVisiblePassword"
                    android:textSize="18sp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/voiceAssistantEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/voice_assistant"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <LinearLayout
                android:id="@+id/voiceAssistantLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_gravity="center_vertical"
                        android:text="@string/voice_assistant_token"
                        android:textSize="18sp" />

                    <EditText
                        android:id="@+id/voiceAssistantToken"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:hint="@string/voice_assistant_token_hint"
                        android:imeOptions="actionDone"
                        android:inputType="textVisiblePassword"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_gravity="center_vertical"
                        android:text="@string/voice_assistant_pipeline_id"
                        android:textSize="18sp" />

                    <EditText
                        android:id="@+id/voiceAssistantPipelineId"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:hint="@string/voice_assistant_pipeline_id_hint"
                        android:imeOptions="actionDone"
                        android:inputType="textUri"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_gravity="center_vertical"
                        android:text="@string/voice_assistant_max_seconds"
                        android:textSize="18sp" />

                    <EditText
                        android:id="@+id/voiceAssistantMaxSeconds"
                        android:layout_width="60dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/voice_assistant_max_seconds_hint"
                        android:imeOptions="actionDone"
                        android:inputType="number"
                        android:textSize="18sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/voiceWakeEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/voice_wake_enabled"
                    android:textSize="18sp"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />

                <LinearLayout
                    android:id="@+id/voiceWakeModelLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/voiceWakeExperimentalModels"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/voice_wake_experimental_models"
                        android:textSize="16sp"
                        tools:ignore="UseSwitchCompatOrMaterialXml" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_gravity="center_vertical"
                            android:text="@string/voice_wake_model_name"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/voiceWakeModelLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_gravity="center_vertical"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textSize="14sp"
                            tools:text="okay_nabu" />

                        <Button
                            android:id="@+id/voiceWakeChooseModel"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/voice_wake_model_choose"
                            android:textSize="13sp" />

                        <ImageButton
                            android:id="@+id/voiceWakeModelRefresh"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@android:drawable/ic_menu_rotate"
                            android:contentDescription="@string/voice_wake_model_refresh"
                            android:background="?attr/selectableItemBackgroundBorderless" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/voiceWakeDownloadProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <ProgressBar
                            android:id="@+id/voiceWakeProgressBar"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="0" />

                        <TextView
                            android:id="@+id/voiceWakeProgressText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textSize="12sp"
                            android:text="0%" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/voiceWakeModelStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="14sp"
                        tools:text="Model status: Loaded" />

                    <TextView
                        android:id="@+id/voiceWakeModelPath"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textSize="12sp"
                        tools:text="Place .tflite file at: /data/.../files/wakewords/" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:text="@string/voice_wake_sensitivity"
                        android:textSize="18sp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/voiceWakeSensitivity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:stepSize="1" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:text="@string/voice_wake_cooldown"
                        android:textSize="18sp" />

                    <com.google.android.material.slider.Slider
                        android:id="@+id/voiceWakeCooldown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:valueFrom="1"
                        android:valueTo="10"
                        android:stepSize="1" />

                </LinearLayout>

                <!-- Wake sound -->
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/voiceWakeSoundEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/voice_wake_sound"
                    android:textSize="18sp"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />

                <!-- Score bar overlay -->
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/voiceScoreBarEnabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/voice_score_bar"
                    android:textSize="18sp"
                    tools:ignore="UseSwitchCompatOrMaterialXml" />

            </LinearLayout>

            <!-- ─────────────── Bluetooth Proxy ─────────────── -->
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/bluetoothProxyEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/bt_proxy_enabled"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

            <LinearLayout
                android:id="@+id/bluetoothProxyLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="48dp"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:text="@string/bt_proxy_name"
                        android:textSize="18sp" />
                    <EditText
                        android:id="@+id/bluetoothProxyName"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:hint="@string/bt_proxy_name_hint"
                        android:imeOptions="actionDone"
                        android:inputType="text"
                        android:textSize="18sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/bluetoothProxyAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="14sp"
                    tools:text="Add to HA: 192.168.1.100:6053" />

            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/liteMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/lite_mode"
                android:textSize="18sp"
                tools:ignore="UseSwitchCompatOrMaterialXml" />

        </LinearLayout>

    </ScrollView>

    <View
        android:id="@+id/swipeDetectionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:focusable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
